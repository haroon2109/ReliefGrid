rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Help for Demo: FULL ACCESS to essential logistics data
    match /{document=**} {
      allow read, write: if true;
    }

    // Keep user profiles semi-protected
    match /users/{userId} {
      allow read: if true; 
      allow write: if request.auth != null;
    }
  }
}
